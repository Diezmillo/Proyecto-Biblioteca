<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Agregar Libro</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-green-100 min-h-screen flex items-center justify-center">

<div class="bg-white p-8 rounded shadow w-full max-w-md">
    <h2 class="text-2xl font-bold mb-6 text-center">Agregar Nuevo Libro</h2>

    <form action="/libros/agregar" method="POST" class="space-y-4">

        <input type="text" name="titulo" placeholder="Título del libro" required
               class="w-full p-3 border rounded">
        <textarea name="descripcion" placeholder="Descripción del libro" required
                  class="w-full p-3 border rounded"></textarea>
        <input type="text" name="imagen" placeholder="URL de la imagen" required
               class="w-full p-3 border rounded">
        <button type="submit"
                class="w-full bg-green-600 text-white p-3 rounded hover:bg-green-700">
            Agregar
        </button>
    </form>
    <a href="/" class="block mt-4 text-center text-gray-600 underline">
        Cancelar
    </a>
</div>
</body>
</html>
<!DOCTYPE html>
<html>
<head>
<title>Prestar libro</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>
    <body class="bg-green-100 flex items-center justify-center min-h-screen">
        <div class="bg-white p-8 rounded shadow w-96">
            <h2 class="text-2xl font-bold mb-4 text-center">Solicitar préstamo</h2>
            <form action="/prestamos/crear/<%= libro.id %>" method="POST">
                <p class="mb-4 font-semibold">Libro: <%= libro.titulo %></p>
                <label>Fecha devolución:</label>
                <input type="date" name="fecha_devolucion" required class="w-full border p-2 rounded mb-4">
                <button class="w-full bg-blue-600 text-white p-2 rounded">Solicitar préstamo</button>
            </form>
            <a href="/" class="block text-center mt-4 underline">Cancelar</a>
        </div>
    </body>
</html>